programa 
{
  funcao inicio() 
  {
    real num1, num2 

    escreva("digite o primeiro número: ")
    leia(num1)

    escreva("digite o segundo número: ")
    leia(num2)

    se (num1 > num2)
    {
      escreva("o maior número é: ", num1)
    }
    senao
    {
      escreva("o maior número é: ", num2)
    }  
  }
}
